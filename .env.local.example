# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=      # server-side only, JANGAN diekspos ke client

# === App ===
# Dipakai untuk emailRedirectTo saat signup (link konfirmasi email).
# Lokal: http://localhost:3000  |  Produksi: https://<domain-vercel-kamu>
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Gemini (dipakai mulai Phase 3) ===
GEMINI_API_KEY=                 # server-side only
GEMINI_MODEL=gemini-2.5-flash   # swappable, harus dukung multimodal
